<?xml version="1.0"?>
<ruleset name="FluentAuthKakao">
    <description>WordPress 보안 규칙 + 프로젝트 스타일 예외</description>

    <file>fluent-auth-kakao.php</file>
    <file>includes/class-kakao-auth.php</file>
    <file>includes/class-kakao-handler.php</file>
    <file>includes/class-plugin.php</file>
    <file>includes/class-settings.php</file>

    <rule ref="WordPress"/>

    <!-- PHP 8 OOP camelCase 스타일 사용 -->
    <rule ref="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.NamingConventions.ValidVariableName.PropertyNotSnakeCase">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.NamingConventions.ValidFunctionName.MethodNameInvalid">
        <severity>0</severity>
    </rule>

    <!-- class-kakao-handler.php 파일명 규칙 충돌 -->
    <rule ref="Squiz.Classes.ClassFileName">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.Files.FileName.InvalidClassFileName">
        <severity>0</severity>
    </rule>

    <!-- 슬래시 포함 훅명: fluent_auth/social_redirect_to 등 외부 플러그인 훅 그대로 사용 -->
    <rule ref="WordPress.NamingConventions.ValidHookName.UseUnderscores">
        <severity>0</severity>
    </rule>

    <!-- 주석 스타일: 팀 선택사항 -->
    <rule ref="Squiz.Commenting.FileComment">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.ClassComment">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.FunctionComment">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.VariableComment.Missing">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.InlineComment.InvalidEndChar">
        <severity>0</severity>
    </rule>
    <rule ref="Generic.Commenting.DocComment.MissingShort">
        <severity>0</severity>
    </rule>

    <!-- Yoda 조건식: PSR 스타일 허용 -->
    <rule ref="WordPress.PHP.YodaConditions">
        <severity>0</severity>
    </rule>

    <!-- 카카오 authorize URL은 외부 URL이므로 wp_redirect() 불가피 -->
    <rule ref="WordPress.Security.SafeRedirect">
        <severity>0</severity>
    </rule>

    <!-- if($x = $y): 2FA URL 할당에서 의도적 사용 -->
    <rule ref="Generic.CodeAnalysis.AssignmentInCondition">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.PHP.DisallowMultipleAssignments.FoundInControl">
        <severity>0</severity>
    </rule>

    <!-- PHP 8 null coalescing ??: WordPress Universal 규칙 충돌 -->
    <rule ref="Universal.Operators.DisallowShortTernary">
        <severity>0</severity>
    </rule>

    <!-- error_log: catch 블록 내 오류 기록 용도로 허용 -->
    <rule ref="WordPress.PHP.DevelopmentFunctions.error_log_error_log">
        <severity>0</severity>
    </rule>

    <!-- fak_kakao_id meta 쿼리: 사용자 수 적은 플러그인이므로 허용 -->
    <rule ref="WordPress.DB.SlowDBQuery">
        <severity>0</severity>
    </rule>

    <!-- Nonce: 소셜 로그인 콜백은 state 파라미터로 CSRF 방지 (Nonce 불필요) -->
    <rule ref="WordPress.Security.NonceVerification">
        <severity>0</severity>
    </rule>
</ruleset>
