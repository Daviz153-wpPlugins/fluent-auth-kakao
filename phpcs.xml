<?xml version="1.0"?>
<ruleset name="FluentAuthKakao">
    <description>WordPress 보안 규칙 + 프로젝트 스타일 예외</description>

    <file>fluent-auth-kakao.php</file>
    <file>includes/class-kakao-auth.php</file>
    <file>includes/class-kakao-handler.php</file>
    <file>includes/class-plugin.php</file>
    <file>includes/class-settings.php</file>

    <rule ref="WordPress"/>

    <!-- 프로젝트가 PHP 8 OOP 스타일(camelCase)을 사용하므로 명명 규칙 제외 -->
    <rule ref="WordPress.NamingConventions.ValidVariableName" />
    <rule ref="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.NamingConventions.ValidFunctionName.MethodNameInvalid">
        <severity>0</severity>
    </rule>

    <!-- 파일명 충돌: class-kakao-handler.php vs KakaoHandler (WordPress 규칙 충돌) -->
    <rule ref="Squiz.Classes.ClassFileName">
        <severity>0</severity>
    </rule>

    <!-- doc comment: 팀 내 선택사항 -->
    <rule ref="Squiz.Commenting.FileComment">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.ClassComment">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.FunctionComment">
        <severity>0</severity>
    </rule>

    <!-- Yoda 조건식: PSR 스타일 허용 -->
    <rule ref="WordPress.PHP.YodaConditions">
        <severity>0</severity>
    </rule>

    <!-- 카카오 authorize URL은 외부 URL이므로 wp_redirect() 사용 불가피 -->
    <rule ref="WordPress.Security.SafeRedirect">
        <severity>0</severity>
    </rule>

    <!-- if($x = $y) 패턴: 2FA URL 할당에서 의도적 사용 -->
    <rule ref="Generic.CodeAnalysis.AssignmentInCondition">
        <severity>0</severity>
    </rule>
</ruleset>
